{
  "uid": "qa-analytics",
  "title": "QA & User Analytics",
  "tags": ["cutdacord", "qa", "users"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Overall Success Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT ROUND(COUNT(*) FILTER (WHERE state = 'AVAILABLE') * 100.0 / NULLIF(COUNT(*), 0), 1) as success_pct FROM jobs WHERE state IN ('AVAILABLE', 'FAILED')",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 75 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 2,
      "title": "Total Downloads",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) FILTER (WHERE state = 'AVAILABLE') as completed FROM jobs",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 3,
      "title": "Total Failures",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) as failed FROM jobs WHERE state = 'FAILED'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 25 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 4,
      "title": "Active Users",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT user_id) as active_users FROM jobs WHERE created_at > NOW() - INTERVAL '7 days'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 5,
      "title": "Bug Reports",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) as reports FROM bug_reports WHERE status != 'resolved'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 6,
      "title": "Unique Failure Reasons",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT SUBSTRING(je.message FROM 1 FOR 80)) as reasons FROM job_events je WHERE je.state = 'FAILED' AND je.created_at > NOW() - INTERVAL '30 days'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 10,
      "title": "Downloads Per User",
      "description": "Completed vs failed per user",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT u.email AS \"User\", COUNT(*) FILTER (WHERE j.state = 'AVAILABLE') AS \"Completed\", COUNT(*) FILTER (WHERE j.state = 'FAILED') AS \"Failed\", COUNT(*) AS \"Total\", ROUND(COUNT(*) FILTER (WHERE j.state = 'AVAILABLE') * 100.0 / NULLIF(COUNT(*), 0), 0) AS \"Success %\" FROM jobs j JOIN users u ON j.user_id = u.id GROUP BY u.email ORDER BY \"Failed\" DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "transparent", "value": null }, { "color": "red", "value": 5 }] } },
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Success %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 50 }, { "color": "green", "value": 75 }] } },
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          }
        ]
      }
    },
    {
      "id": 11,
      "title": "Failure Reasons (Top 10)",
      "description": "Most common failure reasons across all users",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT SUBSTRING(je.message FROM 1 FOR 120) AS \"Reason\", COUNT(*) AS \"Count\", COUNT(DISTINCT j.user_id) AS \"Users Affected\" FROM job_events je JOIN jobs j ON je.job_id = j.id WHERE je.state = 'FAILED' GROUP BY SUBSTRING(je.message FROM 1 FOR 120) ORDER BY \"Count\" DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Count" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "transparent", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 10 }] } },
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          }
        ]
      }
    },
    {
      "id": 20,
      "title": "Recent Failed Downloads",
      "description": "Last 20 failed downloads with user, title, and reason",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT j.updated_at AS \"Time\", u.email AS \"User\", j.title AS \"Title\", j.media_type AS \"Type\", SUBSTRING(je.message FROM 1 FOR 150) AS \"Failure Reason\" FROM jobs j JOIN users u ON j.user_id = u.id LEFT JOIN LATERAL (SELECT message FROM job_events WHERE job_id = j.id AND state = 'FAILED' ORDER BY created_at DESC LIMIT 1) je ON true WHERE j.state = 'FAILED' ORDER BY j.updated_at DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "unit", "value": "dateTimeFromNow" }]
          }
        ]
      }
    },
    {
      "id": 30,
      "title": "Downloads Over Time",
      "description": "Daily completed vs failed downloads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('day', updated_at) AS time, COUNT(*) FILTER (WHERE state = 'AVAILABLE') AS \"Completed\", COUNT(*) FILTER (WHERE state = 'FAILED') AS \"Failed\" FROM jobs WHERE updated_at > NOW() - INTERVAL '30 days' GROUP BY date_trunc('day', updated_at) ORDER BY time",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Completed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 31,
      "title": "User Activity Over Time",
      "description": "Unique active users per day",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('day', created_at) AS time, COUNT(DISTINCT user_id) AS \"Active Users\", COUNT(*) AS \"Requests\" FROM jobs WHERE created_at > NOW() - INTERVAL '30 days' GROUP BY date_trunc('day', created_at) ORDER BY time",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Active Users" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Requests" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      }
    },
    {
      "id": 40,
      "title": "Job State Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 30 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT state AS \"State\", COUNT(*) AS \"Count\" FROM jobs GROUP BY state ORDER BY \"Count\" DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["sum"] }
      }
    },
    {
      "id": 41,
      "title": "Media Type Breakdown",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 30 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT media_type AS \"Type\", state AS \"State\", COUNT(*) AS \"Count\" FROM jobs GROUP BY media_type, state ORDER BY \"Count\" DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "donut"
      }
    },
    {
      "id": 42,
      "title": "User Quota Usage",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 30 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT u.email AS \"User\", u.movie_count AS \"Movies\", u.movie_quota AS \"Movie Quota\", u.tv_count AS \"TV Shows\", u.tv_quota AS \"TV Quota\", u.tier AS \"Tier\" FROM users u ORDER BY u.movie_count + u.tv_count DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 50,
      "title": "Open Bug Reports",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 38 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT br.created_at AS \"Time\", u.email AS \"User\", br.route AS \"Route\", br.description AS \"Description\", br.correlation_id AS \"Correlation ID\", br.status AS \"Status\" FROM bug_reports br JOIN users u ON br.user_id = u.id WHERE br.status != 'resolved' ORDER BY br.created_at DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "unit", "value": "dateTimeFromNow" }]
          }
        ]
      }
    }
  ]
}
