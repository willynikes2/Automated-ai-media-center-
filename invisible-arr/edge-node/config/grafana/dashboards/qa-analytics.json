    {
      "id": 72,
      "title": "Failing Scenarios (Last 7 Days)",
      "description": "Most frequently failing QA scenarios",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 52 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT persona AS \"Persona\", scenario_name AS \"Scenario\", COUNT(*) AS \"Failures\", MAX(created_at) AS \"Last Seen\", SUBSTRING(MAX(error_message) FROM 1 FOR 120) AS \"Latest Error\" FROM qa_results WHERE status IN ('fail', 'error') AND created_at > NOW() - INTERVAL '7 days' GROUP BY persona, scenario_name ORDER BY \"Failures\" DESC LIMIT 15",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Last Seen" },
            "properties": [{ "id": "unit", "value": "dateTimeFromNow" }]
          },
          {
            "matcher": { "id": "byName", "options": "Failures" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "transparent", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 5 }] } },
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          }
        ]
      }
    },
    {
      "id": 73,
