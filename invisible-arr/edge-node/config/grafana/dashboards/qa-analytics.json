      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT persona AS \"Persona\", COUNT(*) FILTER (WHERE status = 'pass') AS \"Passed\", COUNT(*) FILTER (WHERE status IN ('fail', 'error')) AS \"Failed\" FROM qa_results WHERE created_at > NOW() - INTERVAL '7 days' GROUP BY persona ORDER BY persona",
