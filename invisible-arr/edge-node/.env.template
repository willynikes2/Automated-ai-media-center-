# =============================
# CutDaCord.app — Edge Node Env
# =============================

# --- Required (installer will prompt you) ---
TMDB_API_KEY=

# --- Real-Debrid (optional) ---
RD_ENABLED=false
RD_API_TOKEN=
RDT_WEBHOOK_TOKEN=

# --- Zurg streaming (optional) ---
ZURG_ENABLED=false
# Mount that exposes your Zurg library to containers (example):
#   /data/zurg/__all__
ZURG_MOUNT_PATH=/data/zurg/__all__
# Optional HTTP URL base written into .strm files (if empty, file:// paths are used)
# Example: http://zurg:9999/dav/__all__
ZURG_BASE_URL=

# --- Domain / HTTPS (optional) ---
# Set DOMAIN to enable Traefik TLS + subdomain routing:
#   app.DOMAIN  → React PWA frontend
#   api.DOMAIN  → Agent API (FastAPI)
#   media.DOMAIN → Jellyfin (DNS-only in Cloudflare)
#   iptv.DOMAIN → IPTV gateway
#   DOMAIN      → Landing page
DOMAIN=
ACME_EMAIL=

# --- Torrents (qBittorrent with secure DNS, no VPN needed) ---
TORRENT_ENABLED=true
QBT_PASSWORD=

# --- Usenet ---
USENET_ENABLED=false
SABNZBD_API_KEY=

# --- IPTV gateway (optional) ---
IPTV_ENABLED=false

# --- Security (multi-tenant) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# Get from Jellyfin dashboard > Settings > API Keys
JELLYFIN_ADMIN_TOKEN=

# --- AI Smart Retry (optional — leave blank to disable) ---
# Enables LLM-powered retry analysis when downloads fail.
# Supported providers: none, openai, anthropic
LLM_PROVIDER=none
LLM_API_KEY=
LLM_MODEL=

# --- Observability ---
GRAFANA_ADMIN_PASSWORD=changeme

# --- Sentry (optional — leave blank to disable) ---
# Create a Sentry project at https://sentry.io and paste DSNs here
SENTRY_DSN_BACKEND=
VITE_SENTRY_DSN=

# --- Core services ---
POSTGRES_DB=invisible_arr
POSTGRES_USER=invisible_arr
POSTGRES_PASSWORD=CHANGEME_GENERATE_THIS

REDIS_PASSWORD=CHANGEME_GENERATE_THIS

# Docker API version — set to your Docker daemon's API version
# Run: docker version --format '{{.Server.APIVersion}}' to find yours
DOCKER_API_VERSION=1.44

# If your stack uses these internally, keep them predictable:
ENV=dev
LOG_LEVEL=info

# --- Service ports ---
JELLYFIN_PORT=8096
SEERR_PORT=5055
AGENT_API_PORT=8880
QBITTORRENT_PORT=8080
SABNZBD_PORT=8081
IPTV_GATEWAY_PORT=8881
